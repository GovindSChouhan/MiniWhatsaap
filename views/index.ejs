<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MINI_whtsaap</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
   <h3>All chats</h3>
    <form method="GET" action="/chats/new">
        <button>New chats</button>\
        <hr />
    </form>

    
      <%  for(let chat of chats) { %>
    <div class="chat">
        <p>from : <%= chat.from %> </p>
        <div class="message">
         <p><%=chat.message %></p>

         <!--EDIT Route k liye adding edit button-->
         <form method="GET" action="/chats/<%= chat._id %>/edit">
            <button>edit</button>
         </form>
         <br />

        <!--DELETE ROUTR create FOrm plus button for edit -->
         <form method="POST" action="/chats/<%=chat._id%>?_method=DELETE">
            <button>delete</button>
         </form>
        </div>
        <p>Recieved by:  <%=chat.to %> </p>
        <hr /> <!--only time 03:47:17 G-->
        <p><%=chat.created_at.toString().split(" ")[4]%></p><!--Tue Jul 07 2026 03:47:17 GMT+0530 (India Standard Time-->
        <p><%=chat.created_at.toString().split(" ").slice(0, 4).join(" ") %></p>

    </div>
    <br /><br />
    <%}%>


</body>
</html>

  

